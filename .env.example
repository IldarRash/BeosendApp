# --- Database (local Postgres via docker compose) ---
DATABASE_URL=postgres://beosand:beosand@localhost:5432/beosand

# --- Telegram bot ---
# Token from @BotFather
TELEGRAM_BOT_TOKEN=000000000:replace-with-a-real-token

# --- API ---
# Base URL the bot uses to reach apps/api
API_URL=http://localhost:3000
PORT=3000

# --- Roles ---
# Comma-separated Telegram numeric IDs that act as managers/admins
ADMIN_TELEGRAM_IDS=

# --- Admin SPA (apps/admin) ---
# Browser config lives in apps/admin/.env (VITE_API_URL); see apps/admin/.env.example.
# Only VITE_-prefixed vars reach the browser bundle — never put secrets there.
