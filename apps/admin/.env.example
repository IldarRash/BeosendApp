# Browser config for the admin SPA. Only VITE_-prefixed vars reach the bundle.
# Never put server secrets (DATABASE_URL, TELEGRAM_BOT_TOKEN) here.
VITE_API_URL=http://localhost:3000
# Bot username (without @) for the Telegram Login Widget on the login screen.
# Public identifier only — never the bot token.
VITE_TELEGRAM_BOT_USERNAME=BeoSandBot
