# Browser config for the BeoSand Telegram Mini App. Only VITE_-prefixed vars reach
# the bundle. Never put server secrets (DATABASE_URL, TELEGRAM_BOT_TOKEN) here.
VITE_API_URL=http://localhost:3000
# Comma-separated extra hostnames Vite dev should accept (the HTTPS tunnel host,
# e.g. my-app.trycloudflare.com). Telegram requires HTTPS so dev runs behind a
# tunnel; leave blank in plain local dev (any host is allowed then).
VITE_DEV_ALLOWED_HOSTS=
