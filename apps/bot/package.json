  },
  "dependencies": {
    "@beosand/config": "workspace:*",
    "@beosand/i18n": "workspace:*",
    "@beosand/types": "workspace:*",
    "grammy": "^1.34.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  }
}
