    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/schedule": "^6.1.3",
    "drizzle-orm": "^0.38.3",
    "reflect-metadata": "^0.2.2",
